.apply(function() {

    if (.tmp.movetype == null) .tmp.movetype = .Map();

    // Shared per-movetype hazard modifier, in percentage points.
    // The engine hands every room Dive trigger a 0..4 danger tier derived from
    // how the character entered (movetypes.cpp): slink=0, crawl=1,
    // walk/swim/fly=2 (normal), quickly/riding=3, running/flee=4.
    // We center the curve on normal(2): moving more carefully than normal
    // lowers the odds, recklessness raises them, +-20 points per tier.
    // Both the falling "trap" and the "deathtrap" behaviors consult this so the
    // movetype curve lives in exactly one place.
    .tmp.movetype.dangerMod = function(danger) {
	return 20 * (danger - 2);
    };

    // Signed entry-hazard delta by movetype tier, centered on normal(2):
    // slink -30, crawl -20, normal 0, quickly +20, running/flee +30.
    // Positive means a faster/recklessly entry -- more dangerous for placed
    // traps, but safer for gas/exposure hazards, so the caller picks the sign.
    // Magnitude is 20 one tier off normal and 30 at two tiers, matching the
    // 20-30% design. Used by .tmp.spell.canGetRoomAffect as the on-entry dodge.
    .tmp.movetype.entryShift = function(danger) {
	var d; d = danger - 2;
	if (d == 0)
	    return 0;
	var mag;
	if (d == 1 || d == -1)
	    mag = 20;
	else
	    mag = 30;
	if (d < 0)
	    return -1 * mag;
	return mag;
    };

})
