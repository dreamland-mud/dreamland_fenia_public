.apply(function() {
    
    //////////////////// "FALLING" TRAPS ////////////////////
    
    if (.tmp.trap == null) .tmp.trap = .Map();
    
    // Called from onDiveUpdate every 4 seconds. Decreases the death_ground_delay
    // counter and eventually moves the character further.
    .tmp.trap.work = function(ch, trap) {
	if (trap.msgDiveSelf != "") 
	    ch.act(trap.msgDiveSelf, ch);
	
	if (trap.msgDiveOther != "") 
	    ch.recho(trap.msgDiveOther, ch);

	ch.death_ground_delay = ch.death_ground_delay - 1;

	if (ch.death_ground_delay > 0) 
	    return;

	ch.death_ground_delay = 0;
	ch.trap = 0;
	
	var targetRoom; targetRoom = .get_room_index(trap.target);
	
	if (targetRoom == null) {
	    ch.act(trap.msgMoveSelf, ch);
	    ch.recho(trap.msgMoveOther, ch);
	    // Immortals walk the mechanic to test it, but a fall never kills
	    // them: show the would-be-fatal impact instead of raw_kill.
	    if (ch.is_immortal())
		ch.act("Будь ты смертным, удар о землю стал бы последним.", ch);
	    else
		ch.raw_kill(-1, ch, "room");

	} else {
	    // A non-flyer can fall off solid ground INTO the air (a normal plunge),
	    // but can't rise UP out of water into the open air without wings: block
	    // water->air for the unwinged so they stay submerged and face the source
	    // room itself (a drowning underwater "fall spot" keeps them under to
	    // drown), while a flyer is carried on through. Land->air falls are fine.
	    if (ch.in_room != null
		&& ch.in_room.isWater()
		&& targetRoom.sector_type == .tables.sector_table.air
		&& !ch.flying)
		return;

	    // If the landing spot is ITSELF a fall trap, the victim is still in
	    // mid-air over a stacked air column (armageddon's heavens, the aarakocra
	    // eyrie) and will tumble out of it. Hold the ground-impact lines and the
	    // fall damage back for the FINAL room -- real ground or water with no
	    // trap -- so a multi-room descent reads as one continuous fall and hurts
	    // once, not once per layer. (No-op for single-hop traps landing straight
	    // on solid ground, and for the hut/canyon chains that already leave their
	    // intermediate impact messages empty.)
	    var nextTrap; nextTrap = null;
	    if (targetRoom.props != null)
		nextTrap = targetRoom.props.trap;

	    var tSelf; var tOther;
	    if (nextTrap != null) {
		tSelf = "";
		tOther = "";
	    } else {
		tSelf = trap.msgTargetSelf;
		tOther = trap.msgTargetOther;
	    }

	    ch.transfer(
		targetRoom, ch,
		trap.msgMoveOther, trap.msgMoveSelf + "\r\n",
		tOther, tSelf);

	    if (nextTrap != null) {
		// Keep plummeting at full speed: re-arm the fall in the new room so
		// the very NEXT pulse carries the victim one room further down, instead
		// of idling a pulse for the room's standing re-capture (which would also
		// re-print the trap message every layer). Falls must feel fast. Safe
		// against runaway -- each room runs its onDiveUpdate at most once per
		// pulse, and fall chains are acyclic and end on solid ground (the same
		// guarantee the plain target relocate already relies on).
		var ds; ds = nextTrap.divingSpeed; if (ds == null) ds = 1;
		ch.death_ground_delay = ds;
		var fl; fl = nextTrap.flags; if (fl == null) fl = "";
		ch.trap = .tables.trap_flags.values(fl);

	    } else if (trap.dmgPerLevel != null) {
		// Fall damage on the final impact only -- a "level die", level
		// d(dmgPerLevel) of bash, matching the deathtrap non-lethal branch: a
		// survivable fall still hurts and scales with the victim level. Opt-in
		// via dmgPerLevel; relocate-only traps leave it unset and deal nothing.
		// The "room" reason renders the death message right if it proves lethal.
		if (ch.is_immortal()) {
		    // Immortals feel the mechanic but take no real fall damage.
		    ch.act("Будь ты смертным, падение причинило бы тебе боль.", ch);
		} else {
		    var dt; dt = trap.damtype; if (dt == null) dt = "bash";
		    ch.rawdamage(ch, .dice(ch.level, trap.dmgPerLevel), dt, "room");
		}
	    }
	}
    };

    // True for a non-NPC who senses a trap in time to deal with it. The hunter
    // 'detect trap' spell is a paid guarantee (always senses, trains nothing).
    // Otherwise it is the perception skill rolled as a chance that scales with
    // the trained percent -- the keener the eye, the more reliably.
    //
    // train=true is passed by the discrete entry checks (a room entry): they
    // roll luck-aware and let the skill improve. The recurring onDiveUpdate poll
    // passes no train flag, so a standing victim re-rolls each pulse WITHOUT
    // grinding the skill or spamming luck flavour. Once the engine auto-applies
    // the 'detect trap' affect to passive-skill holders (roadmap: passive
    // auto-affects), the affect check alone covers it and this can drop.
    .tmp.trap.detects = function(ch, train) {
	if (ch.is_npc())
	    return false;

	if (ch.isAffected("detect trap"))
	    return true;

	var skill; skill = .Skill("perception");
	if (!skill.usable(ch))
	    return false;

	if (train == true) {
	    var ok; ok = .tmp.chance(skill.effective(ch), ch);
	    skill.improve(ch, ok);
	    return ok;
	}

	return .chance(skill.effective(ch));
    };

    // Called from onDive to see if ch got into this trap.
    // onDive is called if ch enters the room or every 4 seconds when fighting.
    .tmp.trap.matches = function(ch, trap, movedanger, train) {
	// Immortals are deliberately caught so the fall mechanic stays testable;
	// .tmp.trap.work suppresses the actual death/damage for them (flavour only).

	if (!ch.is_npc() && .tmp.player.ghost(ch))
	    return false;

	// 'detect trap' lets a player spot and step around a trap they can SEE --
	// a tripwire, a pit, a slick ledge. It cannot cheat gravity, though: an
	// open-sky tile still drops a wingless walker (the warning just reminds
	// them to fly). Silent otherwise; the trap stays armed for less wary folk.
	if ((ch.in_room == null || ch.in_room.sector_type != .tables.sector_table.air)
	    && .tmp.trap.detects(ch, train))
	    return false;

	// Most traps (except for a few in New Thalos) don't capture flying folks.
	// == true: flyingSafe is optional, so unset reads as NONE -- a bare
	// 'ch.flying && trap.flyingSafe' throws "expected boolean got NONE" for a flyer.
	if (ch.flying && trap.flyingSafe == true)
	    return false;

	// Trap surfaceQuality defaults to 50.
	// Quality 100 would mean trap never works for normal movetype
	// and only reacts to running/fighting. Quality 0 means trap
	// has a chance to be avoided only when moving very carefully.

	// Your chances at avoiding the trap are better if you move
	// more carefully than normal (i.e. with movedanger 1 or 0).
	// Shared movetype curve: +-20 points per danger tier, centered on normal.
	var chance; chance = .tmp.movetype.dangerMod(movedanger);
	
	// Roll the die. For normal move, 50% to avoid the trap;
	// for running/fighting chances are decreased by 20%.
	if (.number_percent() <= 0 + trap.surfaceQuality - chance)
	    return false;

	return true;
    };
    
    // Called from onDive if the trap becomes active for the character.
    .tmp.trap.capture = function(ch, trap) {
	if (!ch.is_npc()) 
	    ch.eraseAttribute("speedwalk");

	if (trap.msgTrapSelf != "") 
	    ch.act(trap.msgTrapSelf, ch);
	    
	if (trap.msgTrapOther != "") 
	    ch.recho(trap.msgTrapOther, ch);

	ch.death_ground_delay = trap.divingSpeed;
	ch.trap = .tables.trap_flags.values(trap.flags);
    };

    // Category of hazard a hunter's 'detect trap' sense would prickle at in the
    // room, or "" for none. "air" = an open-sky tile that drops a wingless
    // walker from the heavens (the .tmp.trap mechanic on an air sector -- you
    // can't slip, there's no ground, you just fall); "fall" = a solid-ground
    // slip-and-fall tile (props.trap, a pit or slick ledge); "trap" = a set trap
    // or hostile cloud (the thief trap plus the mist/venom/ward room-affect
    // family) or a lethal death tile (props.deathtrap). Config lives in the
    // room's props (rooms are not instanced). The detect-trap proximity warning
    // picks its wording from this category.
    .tmp.trap.roomHazard = function(room) {
	if (room == null)
	    return "";

	if (room.props != null) {
	    if (room.props.trap != null) {
		if (room.sector_type == .tables.sector_table.air)
		    return "air";
		return "fall";
	    }
	    if (room.props.deathtrap != null)
		return "trap";
	}

	var names; names = .List();
	names.push_back("settraps");
	names.push_back("shocking trap");
	names.push_back("lightning ward");
	names.push_back("narcotic mist");
	names.push_back("lethargic mist");
	names.push_back("deadly venom");
	names.push_back("black death");
	names.push_back("cursed lands");
	names.push_back("evil spirit");

	var found; found = "";
	var n;
	for (n in names) {
	    if (found == "" && room.isAffected(n))
		found = "trap";
	}
	return found;
    };

})